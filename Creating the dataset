    "---\n",
    "## Section 3: Memory-Efficient Chunked Loading\n",
    "\n",
    "The full BRFSS 2023 XPT file contains over 430,000 rows and more than 300 columns.\n",
    "Loading it entirely into memory at once requires approximately 1.5 GB of RAM, which\n",
    "crashes the kernel in a standard JupyterHub environment.\n",
    "\n",
    "**Solution:** The file is read in chunks of 10,000 rows at a time using `pd.read_sas`\n",
    "with `chunksize=10000`. Only the 14 columns of interest are retained from each chunk\n",
    "before the rest is discarded. This reduces peak memory usage to approximately 150-200 MB.\n",
    "\n",
    "**Column name normalisation:** SAS XPT files occasionally export column names as byte\n",
    "strings (e.g. `b'ADDEPEV3'`). Each chunk's column names are decoded and stripped of\n",
    "whitespace to ensure consistent string matching."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "90085ac1-189d-4edf-b06c-5438d7b5f9ac",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Reading 'LLCP2023.XPT' in chunks of 10,000 rows to conserve memory...\n",
      "Columns found   : ['ADDEPEV3', '_AGE80', 'SEXVAR', 'INCOME3', 'EDUCA', 'MARITAL', '_TOTINDA', '_SMOKER3', '_RFDRHV8', '_BMI5', 'GENHLTH', 'DIABETE4', 'CVDCRHD4', 'ASTHMA3']\n",
      "Chunks processed: 5...10...15...20...25...30...35...40...\n",
      "Total chunks processed: 44\n",
      "\n",
      "Raw subset shape: (433323, 14)\n",
      "Raw subset saved to: brfss2023_depression_subset.csv\n",
      "Temporary files removed.\n"
     ]
    }
   ],
   "source": [
    "print(f\"Reading '{LOCAL_XPT}' in chunks of 10,000 rows to conserve memory...\")\n",
    "\n",
    "chunks      = []\n",
    "chunk_count = 0\n",
    "available_cols = []\n",
    "\n",
    "with pd.read_sas(LOCAL_XPT, format=\"xport\", chunksize=10000) as reader:\n",
    "    for chunk in reader:\n",
    "        # Normalise column names: decode byte strings and strip whitespace\n",
    "        chunk.columns = [\n",
    "            col.decode(\"utf-8\").strip() if isinstance(col, bytes)\n",
    "            else str(col).strip().upper()\n",
    "            for col in chunk.columns\n",
    "        ]\n",
    "\n",
    "        # On the first chunk, identify which desired columns are present in the file\n",
    "        if chunk_count == 0:\n",
    "            available_cols = [c for c in COLS_OF_INTEREST if c in chunk.columns]\n",
    "            missing_cols   = [c for c in COLS_OF_INTEREST if c not in chunk.columns]\n",
    "            print(f\"Columns found   : {available_cols}\")\n",
    "            if missing_cols:\n",
    "                print(f\"Columns missing : {missing_cols}\")\n",
    "            print(\"Chunks processed: \", end=\"\", flush=True)\n",
    "\n",
    "        # Retain only the required columns to discard the 290+ unnecessary ones\n",
    "        chunks.append(chunk[available_cols])\n",
    "        chunk_count += 1\n",
    "\n",
    "        if chunk_count % 5 == 0:\n",
    "            print(f\"{chunk_count}...\", end=\"\", flush=True)\n",
    "\n",
    "print(f\"\\nTotal chunks processed: {chunk_count}\")\n",
    "\n",
    "# Combine all chunks into one dataframe and immediately free the list from memory\n",
    "brfss_raw = pd.concat(chunks, ignore_index=True)\n",
    "del chunks\n",
    "\n",
    "print(f\"\\nRaw subset shape: {brfss_raw.shape}\")\n",
    "brfss_raw.to_csv(SUBSET_CSV, index=False)\n",
    "print(f\"Raw subset saved to: {SUBSET_CSV}\")\n",
    "\n",
    "# Remove the large XPT and ZIP files to free disk space\n",
    "for f in [LOCAL_ZIP, LOCAL_XPT]:\n",
    "    if os.path.exists(f):\n",
    "        os.remove(f)\n",
    "print(\"Temporary files removed.\")"
   ]
