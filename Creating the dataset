    "ZIP_URL    = \"https://www.cdc.gov/brfss/annual_data/2023/files/LLCP2023XPT.zip\"\n",
    "LOCAL_ZIP  = \"LLCP2023XPT.zip\"\n",
    "SUBSET_CSV = \"brfss2023_depression_subset.csv\"\n",
